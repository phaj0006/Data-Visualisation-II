{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "background": "white",

  "spacing": 40,

  "vconcat": [
{
  "width":900,
  "data": {
    "values": [
      { "text": "Tourism in Australia" }
    ]
  },

  "mark": {
    "type": "text",
    "fontSize": 48,
    "fontWeight": "bold",
    "align": "center",
    "color": "#000000"
  },

  "encoding": {
    "text": { "field": "text" }
  }
},
{
  "height": 40,

  "data": {
    "values": [
      {
        "text": [
          "Australian tourism makes up a 213.6 billion dollar industry, with a majority of its revenue from tourism in Victoria and ",
          "New South Wales. Combined, Victoria and New South Wales account for 60% of all Tourism business establishments",
          "in Australia. In this visualisation, the inner workings of the tourism business in Australia is displayed,",
          " involving the main companies in the space and how they compare to each other in revenue and market share ",
          "as well as how these companies make their money and the value provided by employees in the industry. ",
          "Then, a brief analysis of related fields such as hotels and resorts and inbound tour operators and",
          "how these related fields compare to tourism in Australia"
        ]
      }
    ]
  },

  "mark": {
    "type": "text",
    "font": "Frutiger",
    "fontSize": 18,
    "fontWeight": 300,
    "align": "left",
    "color": "#333333"
  },

  "encoding": {
    "text": { "field": "text" }
  }
},
    {
  "width": 900,
  "height": 500,

  "data": {
    "url": "states.geojson"
  },

  "mark": "geoshape",

  "encoding": {
    "tooltip": [
      { "field": "STATE_NAME" },
      { "field": "id" }
    ]
  }
},

    {
  "hconcat": [

    {
      "title": "Tourism Market Share Rankings (2020-2026)",

      "width": 425,
      "height": 500,

      "layer": [
        {
          "data": {
            "url": "data/X0003 Tourism in Australia Industry Report/Market Share History.csv"
          },
          "transform": [
            {
              "fold": [
                "Qantas",
                "Virgin Australia Holdings",
                "Crown Resorts",
                "Flight Centre Travel",
                "Accor Asia Pacific"
              ],
              "as": ["Company", "MarketShare"]
            },
            {
              "calculate": "toNumber(datum.MarketShare)",
              "as": "MarketShareNum"
            },
            {
              "window": [
                {
                  "op": "rank",
                  "as": "Rank"
                }
              ],
              "sort": [
                {
                  "field": "MarketShareNum",
                  "order": "descending"
                }
              ],
              "groupby": ["Year"]
            }
          ],

          "mark": {
            "type": "line",
            "point": true
          },

          "encoding": {
            "x": {
              "field": "Year",
              "type": "ordinal"
            },

            "y": {
              "field": "Rank",
              "type": "ordinal",
              "sort": "descending"
            },

            "color": {
              "field": "Company",
              "type": "nominal"
            },

            "detail": {
              "field": "Company"
            },

            "tooltip": [
              { "field": "Year" },
              { "field": "Company" },
              { "field": "MarketShare" },
              { "field": "Rank" }
            ]
          }
        },

        {
          "data": {
            "values": [
              {
                "Year": "2022",
                "Rank": 1,
                "Label": "Qantas remains the market leader, peaking at 10.21% in 2026"
              }
            ]
          },

          "mark": {
            "type": "text",
            "dx": 40,
            "dy": -10,
            "fontSize": 12,
            "fontWeight": "bold"
          },

          "encoding": {
            "x": {
              "field": "Year",
              "type": "ordinal"
            },

            "y": {
              "field": "Rank",
              "type": "ordinal"
            },

            "text": {
              "field": "Label"
            }
          }
        },

        {
          "data": {
            "values": [
              {
                "Year": "2022",
                "Rank": 4,
                "Label": "The other rankings stabilise to their final positions in 2022"
              }
            ]
          },

          "mark": {
            "type": "text",
            "dx": 40,
            "dy": -10,
            "fontSize": 12,
            "fontWeight": "bold"
          },

          "encoding": {
            "x": {
              "field": "Year",
              "type": "ordinal"
            },

            "y": {
              "field": "Rank",
              "type": "ordinal"
            },

            "text": {
              "field": "Label"
            }
          }
        }
      ]
    },

    {
  "title": "Company Market Share vs Revenue (2026)",

  "width": 425,
  "height": 500,

  "layer": [

    {
      "data": {
        "url": "data/X0003 Tourism in Australia Industry Report/Companies.csv"
      },

      "mark": {
        "type": "point",
        "filled": true,
        "size": 250
      },

      "encoding": {
        "x": {
          "field": "Market Share (%)2026",
          "type": "quantitative",
          "title": "Company Market Share (%)"
        },

        "y": {
          "field": "Revenue ($m)2026",
          "type": "quantitative",
          "title": "Revenue ($ million)"
        },

        "tooltip": [
          { "field": "Company" },
          { "field": "Market Share (%)2026" },
          { "field": "Revenue ($m)2026" }
        ]
      }
    },

    {
      "data": {
        "values": [
          {
            "Market Share (%)2026": 4,
            "Revenue ($m)2026": 21000,
            "Label": [
              "This has led to a staggering 21.4 billion dollars of revenue for Qantas.",
              "This is 3.7x the revenue of its closest competitor, Virgin Australia."
            ]
            }
        ]
      },

      "mark": {
        "type": "text",
        "dx": 40,
        "dy": -10,
        "fontSize": 12,
        "fontWeight": "bold"
      },

      "encoding": {
        "x": {
          "field": "Market Share (%)2026",
          "type": "quantitative"
        },

        "y": {
          "field": "Revenue ($m)2026",
          "type": "quantitative"
        },

        "text": {
          "field": "Label"
        }
      }
    }
  ]
}
  ]
},

{
  "title": "Revenue Per Employee vs Average Wage",

  "width": 900,
  "height": 500,

  "data": {
    "url": "data/X0003 Tourism in Australia Industry Report/Key Ratios.csv"
  },

  "transform": [
    {
      "fold": [
        "Revenue per Employee($)",
        "Average Wage($)"
      ],
      "as": ["Metric", "Value"]
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "line",
        "point": true
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },

        "y": {
          "field": "Value",
          "type": "quantitative",
          "title": "Amount of Money ($)"
        },

        "color": {
          "field": "Metric",
          "type": "nominal"
        },

        "tooltip": [
          { "field": "Year" },
          { "field": "Metric" },
          { "field": "Value" }
        ]
      }
    },

    {
  "data": {
    "values": [
      {
        "label": [
          "Interestingly, despite producing $300,000 of value,",
          "employees only make on average $50,000-$60,000 per year.",
          "This is 5-6x less than the value they produce."
        ]
      }
    ]
  },

  "mark": {
    "type": "text",
    "fontSize": 14,
    "fontWeight": "bold",
    "font": "Frutiger",
    "color": "#666666",
    "align": "center",
    "baseline": "middle",
    "dx": 0,
    "dy": 0
  },

  "encoding": {
    "text": { "field": "label" },

    "x": { "value": 450 },
    "y": { "value": 250 }
  }
}
  ]
},

{
  "title": "Revenue Distribution",

  "width": 900,
  "height": 500,

  "data": {
    "url": "data/X0003 Tourism in Australia Industry Report/Products And Services.csv"
  },

  "transform": [
    {
      "calculate": "datum.Revenue / 1000000",
      "as": "RevenueMillions"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "bar"
      },

      "encoding": {
        "x": {
          "field": "Segment",
          "type": "nominal",
          "sort": "-y",
          "title": null
        },

        "y": {
          "field": "RevenueMillions",
          "type": "quantitative",
          "title": "Revenue ($ million)"
        },

        "tooltip": [
          { "field": "Segment" },
          {
            "field": "RevenueMillions",
            "title": "Revenue ($ million)",
            "format": ",.2f"
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          {
            "label": [
              "Tourism gains a majority of its revenue from Transport, Retailing and Accommendation.",
              "This makes up 70.8% of all revenue generated by Australia tourism businesses"
            ]
          }
        ]
      },

      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "font": "Frutiger",
        "color": "#666666",
        "align": "right",
        "baseline": "top"
      },

      "encoding": {
        "text": { "field": "label" },

        "x": { "value": 880 },
        "y": { "value": 10 }
      }
    }
  ]
},
