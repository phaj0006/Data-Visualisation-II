{
  "width":900,
  "data": {
    "values": [
      { "text": "Inbound Tour Operators" }
    ]
  },

  "mark": {
    "type": "text",
    "fontSize": 30,
    "fontWeight": "bold",
    "align": "center",
    "color": "#000000"
  },

  "encoding": {
    "text": { "field": "text" }
  }
},
{
  "hconcat": [
    {
      "title": "Business Market Share (2026)",

      "width": 425,
      "height": 500,

      "data": {
        "url": "Data/OD5397 Inbound Tour Operators in Australia Industry Report/Companies.csv"
      },

      "transform": [
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "Market Share (%)2026",
              "as": "MarketShare"
            }
          ],
          "groupby": ["Company"]
        },

        {
          "joinaggregate": [
            {
              "op": "sum",
              "field": "MarketShare",
              "as": "TotalShare"
            }
          ]
        },

        {
          "calculate": "datum.MarketShare / datum.TotalShare",
          "as": "Percent"
        }
      ],

      "layer": [
        {
          "mark": {
            "type": "arc",
            "innerRadius": 120
          },

          "encoding": {
            "theta": { "field": "MarketShare", "type": "quantitative" },
            "color": { "field": "Company", "type": "nominal" },

            "tooltip": [
              { "field": "Company" },
              { "field": "MarketShare", "title": "Market Share" },
              {
                "field": "Percent",
                "type": "quantitative",
                "format": ".1%"
              }
            ]
          }
        },

        {
          "mark": {
            "type": "text",
            "fontSize": 12,
            "fontWeight": "bold",
            "align": "center",
            "baseline": "middle"
          },

          "encoding": {
            "text": {
              "value": [
                "Out of the 10.4% combined market share,",
                "Hello World has 7x the market share",
                "at 9.1% compared to Across Australia's",
                "1.3% market share"
              ]
            }
          }
        }
      ]
    },

    {
  "title": "Industry Revenue Over Time",

  "width": 425,
  "height": 500,

  "layer": [

    {
      "data": {
        "url": "Data/OD5397 Inbound Tour Operators in Australia Industry Report/Industry Data.csv"
      },

      "transform": [
        {
          "calculate": "toNumber(datum['Revenue($ Million)'])",
          "as": "RevenueMillion"
        }
      ],

      "mark": {
        "type": "area",
        "line": true,
        "opacity": 0.6
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year"
        },

        "y": {
          "field": "RevenueMillion",
          "type": "quantitative",
          "title": "Revenue ($ Million)"
        },

        "tooltip": [
          {
            "field": "Year"
          },
          {
            "field": "RevenueMillion",
            "title": "Revenue ($M)"
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          {
            "Year": "2020-21",
            "RevenueMillion": 800,
            "Label": [
              "COVID-19 travel restrictions",
              "caused a significant decline",
              "in inbound tourism revenue,",
              "which sharply recovered in 2023",
              "where restrictions are lifted"
            ]
          }
        ]
      },

      "mark": {
        "type": "text",
        "dx": 60,
        "dy": -20,
        "fontSize": 12,
        "fontWeight": "bold"
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },

        "y": {
          "field": "RevenueMillion",
          "type": "quantitative"
        },

        "text": {
          "field": "Label"
        }
      }
    }

  ]
}
